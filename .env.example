PRIVATE_KEY=

# RPC URLs (defaults available in hardhat.config.ts if not set)
RPC_URL_ADI_TESTNET=https://rpc.testnet.adifoundation.ai
RPC_URL_BASE_SEPOLIA_TESTNET=https://sepolia.base.org
RPC_URL_AMOY_TESTNET=https://rpc-amoy.polygon.technology
RPC_URL_CITREA_TESTNET=https://rpc.testnet.citrea.xyz
RPC_URL_ETHEREUM_SEPOLIA_TESTNET=https://rpc.sepolia.org

# Chainlink CCIP router addresses (required for CCIP adapter deployments)
CCIP_ROUTER_ADI_TESTNET=0x5D445DF89674096B6A138565cAE955FF816f352D
CCIP_ROUTER_BASE_SEPOLIA_TESTNET=0xD3b06cEbF099CE7DA4AcCf578aaebFDBd6e88a93
CCIP_ROUTER_AMOY_TESTNET=0x9C32fCB86BF0f4a1A8921a9Fe46de3198bb884B2
# CCIP_ROUTER_CITREA_TESTNET= # CCIP does not support this chain.
CCIP_ROUTER_ETHEREUM_SEPOLIA_TESTNET=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59

# Chainlink CCIP chain selectors (defaults available in config if not set)
# CCIP_CHAIN_SELECTOR_ADI_TESTNET=9418205736192840573
# CCIP_CHAIN_SELECTOR_BASE_SEPOLIA_TESTNET=10344971235874465080
# CCIP_CHAIN_SELECTOR_AMOY_TESTNET=16281711391670634445
# CCIP_CHAIN_SELECTOR_CITREA_TESTNET= # CCIP does not support this chain.
# CCIP_CHAIN_SELECTOR_ETHEREUM_SEPOLIA_TESTNET=16015286601757825753

# Governance owners (Safe/timelock addresses)
BRIDGE_OWNER_ADI_TESTNET=
BRIDGE_OWNER_BASE_SEPOLIA_TESTNET=
BRIDGE_OWNER_AMOY_TESTNET=
BRIDGE_OWNER_CITREA_TESTNET=
